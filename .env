# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set your actual API key here for production deployment
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted
# Update this for production deployment
APP_URL="http://localhost:3000"

# NODE_ENV: Set to 'production' when deploying to hosting
NODE_ENV="development"

# PORT: Server port (hosting platforms may override this via PORT env var)
# PORT=3000
